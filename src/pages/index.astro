---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const featured = allArticles[0];
---

<Layout title="Dashboard — The Living Library">
  <div class="min-h-screen p-8 md:p-12 animate-in">

    <header class="mb-12">
      <span class="text-[10px] font-mono text-green-500 uppercase tracking-[0.3em] block mb-2">&gt; DASHBOARD / OVERVIEW</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight">Control Room</h1>
    </header>

    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="bg-neutral-900 border border-neutral-800 p-6 rounded">
        <div class="text-[10px] font-mono text-neutral-500 uppercase mb-2">Total Seeds</div>
        <div class="text-4xl font-bold text-white">{allArticles.length}</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-6 rounded">
        <div class="text-[10px] font-mono text-neutral-500 uppercase mb-2">Last Updated</div>
        <div class="text-4xl font-bold text-white">{featured?.data.date ?? '—'}</div>
      </div>
      <div class="bg-neutral-900 border border-neutral-800 p-6 rounded">
        <div class="text-[10px] font-mono text-neutral-500 uppercase mb-2">System Status</div>
        <div class="text-4xl font-bold text-green-500">ACTIVE</div>
      </div>
    </div>

    {featured && (
      <div class="bg-neutral-900/50 border border-neutral-800 p-8 rounded">
        <span class="text-[10px] font-mono text-blue-500 uppercase tracking-widest block mb-4">Featured Artifact</span>
        <h2 class="text-2xl font-bold text-white mb-2">{featured.data.title}</h2>
        <p class="text-neutral-400 font-serif italic mb-6">{featured.data.commentary}</p>
        <a
          href={`/view/${featured.data.slug}`}
          class="inline-block bg-white text-black font-mono text-xs px-4 py-2 hover:bg-blue-500 hover:text-white transition-colors uppercase tracking-wider"
        >
          View Artifact →
        </a>
      </div>
    )}

    <div class="mt-12">
      <a
        href="/prompts"
        class="inline-block border border-neutral-700 px-6 py-3 font-mono text-xs text-neutral-400 hover:text-white hover:border-white transition-colors uppercase tracking-widest"
      >
        OPEN PROMPT LAB
      </a>
    </div>
  </div>
</Layout>
