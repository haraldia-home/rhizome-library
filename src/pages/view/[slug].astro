---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const seed = entry.data;
---

<Layout title={`${seed.title} — The Living Library`}>
  <div class="min-h-screen bg-black text-neutral-200 animate-in fade-in duration-700 selection:bg-blue-500 selection:text-white pb-24">

    {/* --- LAYOUT 1: THE COURSE --- */}
    {seed.format === 'course' && (
      <main class="max-w-4xl mx-auto py-10 md:py-20 px-4 md:px-6">
        <header class="mb-8 md:mb-12 border-l-4 border-blue-500 pl-4 md:pl-6">
          <span class="text-[10px] font-mono text-blue-500 uppercase tracking-[0.3em]">Curriculum Protocol</span>
          <h1 class="text-3xl md:text-5xl lg:text-7xl font-bold text-white mt-2 mb-4 tracking-tighter">{seed.title}</h1>
          <p class="text-base md:text-xl text-neutral-400 font-serif italic leading-relaxed">"{seed.commentary}"</p>
        </header>

        <div class="grid gap-6">
          <div class="bg-neutral-900/50 p-6 rounded border border-neutral-800 mb-8">
            <h3 class="font-mono text-xs text-green-500 mb-2">&gt; ABSTRACT</h3>
            <div class="font-serif text-lg leading-relaxed text-neutral-300 prose prose-invert max-w-none">
              <Content />
            </div>
          </div>

          <h2 class="font-mono text-xs text-neutral-500 uppercase tracking-widest mb-4">Reading Path</h2>

          {seed.chapters?.map((chapter, i) => (
            <div class="group flex flex-col md:flex-row gap-6 p-6 border border-neutral-800 hover:border-blue-500 transition-all bg-neutral-900/20 items-start md:items-center">
              <div class="text-4xl font-bold text-neutral-800 group-hover:text-blue-500/50 font-serif">
                {i + 1 < 10 ? `0${i + 1}` : i + 1}
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-white mb-1 group-hover:text-blue-400 transition-colors">{chapter.title}</h3>
                <p class="text-sm text-neutral-400 font-mono">Auth: {chapter.author}</p>
              </div>
              <div class="w-full md:w-1/3 bg-black p-4 rounded border border-neutral-800">
                <span class="text-[10px] text-green-500 block mb-1">FOCUS AREA:</span>
                <p class="text-xs text-neutral-300 mb-3">{chapter.focus}</p>
                <a
                  href={`https://www.google.com/search?q=${encodeURIComponent(chapter.link)}`}
                  target="_blank"
                  class="text-[10px] font-bold bg-white text-black px-2 py-1 hover:bg-blue-500 hover:text-white transition-colors block text-center uppercase tracking-wider"
                >
                  Search Source →
                </a>
              </div>
            </div>
          ))}
        </div>
      </main>
    )}

    {/* --- LAYOUT 2: SURREALISM --- */}
    {seed.format === 'surrealism' && (
      <main class="min-h-screen flex flex-col items-center justify-center p-6 relative overflow-hidden bg-white text-black">
        <div class="absolute inset-0 overflow-hidden opacity-5 pointer-events-none select-none">
          <h1 class="text-[15vw] md:text-[20vw] font-bold leading-none -ml-10 md:-ml-20">ABSURD</h1>
          <h1 class="text-[15vw] md:text-[20vw] font-bold leading-none ml-10 md:ml-20">REALITY</h1>
        </div>

        <div class="z-10 max-w-2xl text-center">
          <span class="bg-black text-white px-2 py-1 text-xs font-mono uppercase transform -rotate-3 inline-block mb-8">
            {seed.pillar}
          </span>
          <h1 class="text-4xl md:text-6xl lg:text-8xl font-serif font-black mb-8 hover:italic transition-all cursor-help glitch-hover">
            {seed.title}
          </h1>
          {seed.mediaUrl && (
            <div class="relative inline-block my-8 transform rotate-2 hover:rotate-0 transition-transform duration-500">
              <img src={seed.mediaUrl} class="max-w-md w-full shadow-[10px_10px_0px_0px_rgba(0,0,0,1)] border-2 border-black filter contrast-125" />
            </div>
          )}
          <div class="text-lg md:text-2xl font-serif leading-relaxed border-t-2 border-black pt-8 mt-8 prose prose-lg max-w-none">
            <Content />
          </div>
          <p class="text-xs font-mono mt-12 text-neutral-500">
            {seed.commentary}
          </p>
        </div>
      </main>
    )}

    {/* --- LAYOUT 3: POETRY --- */}
    {seed.format === 'poetry' && (
      <main class="max-w-2xl mx-auto py-12 md:py-24 px-4 md:px-6 text-center">
        <span class="text-[10px] font-mono text-blue-500 mb-8 block tracking-widest uppercase border border-blue-900/30 inline-block px-3 py-1 rounded-full">
          {seed.pillar} // Poetic Node
        </span>
        <h1 class="text-3xl md:text-4xl lg:text-6xl font-serif font-bold mb-10 md:mb-16 italic text-white leading-tight">
          {seed.title}
        </h1>
        <div class="font-serif text-lg md:text-2xl leading-relaxed whitespace-pre-line text-neutral-300 italic border-l-2 border-neutral-800 pl-6 md:border-none md:pl-0 prose prose-invert prose-lg max-w-none">
          <Content />
        </div>
        <div class="mt-16 text-[10px] font-mono text-neutral-600 uppercase tracking-widest">
          Generated: {seed.date}
        </div>
      </main>
    )}

    {/* --- LAYOUT 4: ESSAY / SATIRE --- */}
    {(seed.format === 'essay' || seed.format === 'satire') && (
      <main class="max-w-3xl mx-auto py-10 md:py-16 px-4 md:px-6">
        <header class="border-b-4 border-white/10 mb-8 md:mb-12 pb-6">
          <div class="flex justify-between items-end mb-4">
            <span class="bg-white text-black font-bold px-2 py-1 text-[10px] uppercase tracking-tighter">THE DAILY RHIZOME</span>
            <span class="font-mono text-[10px] text-neutral-500">{seed.date}</span>
          </div>
          <h1 class="text-3xl md:text-4xl lg:text-6xl font-bold text-white leading-none tracking-tight mb-4 md:mb-6">{seed.title}</h1>
          <p class="text-base md:text-xl text-neutral-400 font-serif italic pl-4 md:pl-6 border-l-2 border-blue-500 leading-relaxed">"{seed.commentary}"</p>
        </header>

        {seed.mediaUrl && (
          <div class="mb-12 relative group">
            <img src={seed.mediaUrl} class="w-full h-80 object-cover grayscale group-hover:grayscale-0 transition-all duration-700 rounded-sm" />
            <div class="absolute bottom-2 right-2 text-[9px] font-mono text-white/50">FIG. 1.0</div>
          </div>
        )}

        <article class="prose prose-invert prose-lg text-neutral-300 font-serif leading-loose max-w-none [&>p]:mb-6 [&>p:first-of-type]:first-letter:text-5xl [&>p:first-of-type]:first-letter:font-bold [&>p:first-of-type]:first-letter:text-white [&>p:first-of-type]:first-letter:mr-2 [&>p:first-of-type]:first-letter:float-left">
          <Content />
        </article>
      </main>
    )}

    {/* --- LAYOUT 5: CODE --- */}
    {seed.format === 'code' && (
      <main class="max-w-6xl mx-auto py-12 md:py-24 px-6 grid md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1">
          <span class="text-[10px] font-mono text-green-500 mb-4 block">&gt; SYSTEM.EXECUTE({seed.pillar.toUpperCase()})</span>
          <h1 class="text-4xl font-bold text-white mb-6">{seed.title}</h1>
          <p class="text-neutral-400 mb-8 font-serif text-lg leading-relaxed">{seed.commentary}</p>

          <div class="bg-black border border-neutral-800 p-6 rounded-lg font-mono text-xs md:text-sm text-green-400 shadow-[0_0_30px_rgba(0,255,0,0.1)] overflow-x-auto">
            <div class="flex gap-2 mb-4 border-b border-white/10 pb-2">
              <div class="w-2 h-2 rounded-full bg-red-500"></div>
              <div class="w-2 h-2 rounded-full bg-yellow-500"></div>
              <div class="w-2 h-2 rounded-full bg-green-500"></div>
            </div>
            <div class="prose prose-invert prose-sm max-w-none [&>*]:text-green-400">
              <Content />
            </div>
          </div>
        </div>

        {seed.mediaUrl && (
          <div class="relative group order-1 md:order-2">
            <div class="absolute inset-0 bg-blue-500/20 blur-3xl opacity-20"></div>
            <img src={seed.mediaUrl} class="relative rounded-lg shadow-2xl border border-neutral-800 opacity-90 group-hover:opacity-100 transition-opacity" />
            <div class="absolute -bottom-4 -right-4 bg-neutral-900 text-[10px] px-3 py-1 border border-neutral-700 font-mono text-green-500">
              RENDER COMPLETE
            </div>
          </div>
        )}
      </main>
    )}

    {/* --- LAYOUT 6: MEDIA --- */}
    {seed.format === 'media' && (
      <main class="h-[calc(100vh-2rem)] flex flex-col justify-center items-center bg-neutral-900 relative overflow-hidden m-4 rounded-3xl border border-neutral-800">
        {seed.mediaUrl && (
          <div class="absolute inset-0 opacity-30 blur-3xl scale-110">
            <img src={seed.mediaUrl} class="w-full h-full object-cover" />
          </div>
        )}
        <div class="z-10 text-center relative max-w-2xl px-6">
          <div class="w-64 h-64 md:w-96 md:h-96 mx-auto bg-black border border-neutral-700 shadow-2xl mb-12 relative group cursor-pointer hover:scale-105 transition-transform rounded-full overflow-hidden">
            {seed.mediaUrl && (
              <img
                src={seed.mediaUrl}
                class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity animate-spin"
                style="animation-duration: 20s;"
              />
            )}
            <div class="absolute inset-0 flex items-center justify-center backdrop-blur-sm group-hover:backdrop-blur-none transition-all">
              <div class="bg-white text-black rounded-full w-20 h-20 flex items-center justify-center pl-1 hover:scale-110 transition-transform">▶</div>
            </div>
          </div>
          <h1 class="text-3xl md:text-5xl font-bold text-white mb-4 tracking-tight">{seed.title}</h1>
          <p class="text-blue-400 font-mono text-xs tracking-[0.2em] uppercase mb-8 md:mb-12">{seed.pillar}</p>
          <div class="w-full h-1 bg-neutral-700 rounded-full overflow-hidden mb-4">
            <div class="w-1/3 h-full bg-white"></div>
          </div>
          <div class="flex justify-between text-[10px] font-mono text-neutral-400">
            <span>0:00</span>
            <span>∞:∞</span>
          </div>
        </div>
      </main>
    )}

    {/* --- LAYOUT 7: MANIFESTO --- */}
    {seed.format === 'manifesto' && (
      <main class="max-w-3xl mx-auto py-10 md:py-20 px-4 md:px-6">
        <header class="mb-10 md:mb-16 text-center border-b-2 border-red-500/30 pb-8 md:pb-12">
          <span class="text-[10px] font-mono text-red-500 uppercase tracking-[0.4em] block mb-4 md:mb-6">Declaration</span>
          <h1 class="text-3xl md:text-5xl lg:text-7xl font-serif font-black text-white leading-none tracking-tight mb-6 md:mb-8">{seed.title}</h1>
          <p class="text-base md:text-xl text-neutral-400 font-serif italic max-w-xl mx-auto leading-relaxed">"{seed.commentary}"</p>
        </header>
        {seed.mediaUrl && (
          <div class="mb-12 relative group">
            <img src={seed.mediaUrl} class="w-full h-64 object-cover opacity-60 group-hover:opacity-90 transition-all duration-700 rounded-sm" />
          </div>
        )}
        <article class="prose prose-invert prose-lg text-neutral-300 font-serif leading-loose max-w-none [&>h2]:font-mono [&>h2]:text-sm [&>h2]:uppercase [&>h2]:tracking-widest [&>h2]:text-red-500 [&>h2]:mt-16 [&>h2]:mb-6 [&>blockquote]:border-l-red-500 [&>blockquote]:text-neutral-200 [&>hr]:border-neutral-800">
          <Content />
        </article>
      </main>
    )}

    {/* --- LAYOUT 8: THEOREM --- */}
    {seed.format === 'theorem' && (
      <main class="max-w-3xl mx-auto py-10 md:py-20 px-4 md:px-6">
        <header class="mb-8 md:mb-12 border-l-4 border-amber-500 pl-4 md:pl-6">
          <span class="text-[10px] font-mono text-amber-500 uppercase tracking-[0.3em]">Formal Argument</span>
          <h1 class="text-2xl md:text-4xl lg:text-6xl font-bold text-white mt-2 mb-4 tracking-tighter">{seed.title}</h1>
          <p class="text-base md:text-lg text-neutral-400 font-serif italic leading-relaxed">"{seed.commentary}"</p>
        </header>
        <article class="prose prose-invert prose-lg text-neutral-300 max-w-none [&>h2]:font-mono [&>h2]:text-xs [&>h2]:uppercase [&>h2]:tracking-widest [&>h2]:text-amber-500 [&>h2]:mt-16 [&>h2]:mb-6 [&>blockquote]:border-l-amber-500/50 [&>blockquote]:text-amber-200/80 [&>blockquote]:font-mono [&>blockquote]:text-sm [&>hr]:border-neutral-800 [&>p>strong]:text-white">
          <Content />
        </article>
      </main>
    )}

    {/* --- LAYOUT 9: CHRONICLE --- */}
    {seed.format === 'chronicle' && (
      <main class="max-w-3xl mx-auto py-10 md:py-16 px-4 md:px-6">
        <header class="border-b-4 border-white/10 mb-12 pb-6">
          <div class="flex justify-between items-end mb-4">
            <span class="bg-neutral-800 text-neutral-300 font-bold px-2 py-1 text-[10px] uppercase tracking-tighter">Chronicle</span>
            <span class="font-mono text-[10px] text-neutral-500">{seed.date}</span>
          </div>
          <h1 class="text-4xl md:text-6xl font-bold text-white leading-none tracking-tight mb-6">{seed.title}</h1>
          <p class="text-xl text-neutral-400 font-serif italic pl-6 border-l-2 border-neutral-600">"{seed.commentary}"</p>
        </header>
        {seed.mediaUrl && (
          <div class="mb-12">
            <img src={seed.mediaUrl} class="w-full h-80 object-cover grayscale rounded-sm" />
          </div>
        )}
        <article class="prose prose-invert prose-lg text-neutral-300 font-serif leading-loose max-w-none [&>h2]:font-sans [&>h2]:text-white [&>hr]:border-neutral-800">
          <Content />
        </article>
      </main>
    )}

    {/* --- LAYOUT 10: DIALOGUE --- */}
    {seed.format === 'dialogue' && (
      <main class="max-w-3xl mx-auto py-10 md:py-20 px-4 md:px-6">
        <header class="mb-8 md:mb-12 text-center">
          <span class="text-[10px] font-mono text-purple-500 uppercase tracking-[0.4em] block mb-4 md:mb-6">Dialectical Exchange</span>
          <h1 class="text-3xl md:text-4xl lg:text-6xl font-serif font-bold text-white mb-4 md:mb-6 leading-tight">{seed.title}</h1>
          <p class="text-base md:text-lg text-neutral-400 font-serif italic leading-relaxed">"{seed.commentary}"</p>
        </header>
        <article class="prose prose-invert prose-lg text-neutral-300 max-w-none [&>h2]:font-mono [&>h2]:text-sm [&>h2]:uppercase [&>h2]:tracking-widest [&>h2]:text-purple-400 [&>h2]:mt-14 [&>h2]:mb-6 [&>h3]:text-white [&>h3]:font-serif [&>blockquote]:border-l-purple-500/50 [&>blockquote]:text-purple-200/80 [&>hr]:border-neutral-800">
          <Content />
        </article>
      </main>
    )}

    {/* --- LAYOUT 11: TREATISE --- */}
    {seed.format === 'treatise' && (
      <main class="max-w-4xl mx-auto py-10 md:py-20 px-4 md:px-6">
        <header class="mb-10 md:mb-16 border-b border-neutral-800 pb-6 md:pb-8">
          <span class="text-[10px] font-mono text-cyan-500 uppercase tracking-[0.3em] block mb-4">{seed.pillar} — Treatise</span>
          <h1 class="text-2xl md:text-4xl lg:text-6xl font-bold text-white mb-4 tracking-tight">{seed.title}</h1>
          <p class="text-base md:text-lg text-neutral-400 font-serif italic leading-relaxed">"{seed.commentary}"</p>
        </header>
        {seed.mediaUrl && (
          <div class="mb-12 relative group">
            <img src={seed.mediaUrl} class="w-full h-72 object-cover opacity-50 group-hover:opacity-80 transition-all duration-700 rounded-sm" />
            <div class="absolute bottom-2 right-2 text-[9px] font-mono text-white/50">FIGURE 1</div>
          </div>
        )}
        <article class="prose prose-invert prose-lg text-neutral-300 max-w-none [&>h2]:font-mono [&>h2]:text-sm [&>h2]:uppercase [&>h2]:tracking-widest [&>h2]:text-cyan-500 [&>h2]:mt-16 [&>h2]:mb-6 [&>h3]:text-white [&>h3]:text-lg [&>blockquote]:border-l-cyan-500/50 [&>blockquote]:text-cyan-200/70 [&>hr]:border-neutral-800 [&>ul]:text-neutral-400 [&>p>strong]:text-white">
          <Content />
        </article>
      </main>
    )}

    {/* --- SHARED FOOTER WITH TAGS --- */}
    <footer class="w-full max-w-4xl mx-auto mt-16 px-6">
      <div class="border-t border-white/10 pt-8">
        <span class="text-[10px] font-mono text-neutral-500 uppercase tracking-widest block mb-4">
          Connect to Node:
        </span>
        <div class="flex flex-wrap gap-2">
          {seed.tags.map((tag) => (
            <a
              href={`/topics/${tag}`}
              class="text-[10px] font-mono text-blue-400 border border-blue-900/30 px-3 py-1.5 rounded hover:bg-blue-900/20 hover:text-blue-300 transition-colors uppercase"
            >
              #{tag}
            </a>
          ))}
        </div>
      </div>

      <div class="mt-8 pt-8 flex justify-between items-center text-[10px] font-mono text-neutral-600">
        <span>ID: {entry.id}</span>
        <a href="/prompts" class="hover:text-white transition-colors">
          [ RETURN TO ARCHIVE ]
        </a>
      </div>
    </footer>

  </div>
</Layout>
