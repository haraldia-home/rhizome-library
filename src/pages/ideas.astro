---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
---

<Layout title="Ideas Timeline — The Living Library">
  <div class="min-h-screen p-8 md:p-12 animate-in">
    <header class="mb-12">
      <span class="text-[10px] font-mono text-green-500 uppercase tracking-[0.3em] block mb-2">&gt; IDEAS / TIMELINE</span>
      <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight">Ideas Timeline</h1>
    </header>

    <div class="relative border-l border-neutral-800 ml-4 md:ml-8 space-y-12">
      {allArticles.map((entry) => (
        <article class="relative pl-8">
          <div class="absolute -left-[5px] top-2 w-2.5 h-2.5 bg-neutral-700 rounded-full border-2 border-neutral-950"></div>
          <div class="text-[10px] font-mono text-neutral-600 mb-2">{entry.data.date}</div>
          <span class="text-[9px] font-mono text-blue-400 uppercase tracking-wider">{entry.data.pillar}</span>
          <a href={`/view/${entry.slug}`} class="block group">
            <h2 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors mt-1 mb-2">{entry.data.title}</h2>
          </a>
          <p class="text-sm text-neutral-400 font-serif italic mb-3">{entry.data.commentary}</p>
          <div class="flex flex-wrap gap-1">
            {entry.data.tags.map((tag) => (
              <a href={`/topics/${tag}`} class="text-[9px] font-mono text-neutral-600 border border-neutral-800 px-1.5 py-0.5 rounded hover:text-blue-400 hover:border-blue-900 transition-colors">#{tag}</a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>
